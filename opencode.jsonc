{
  "$schema": "https://opencode.ai/config.json",
  // Keep project-level behavior predictable
  //   "instructions": ["instructions.md"],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-b3c6b84b-5f6a-4569-9fbc-0f4ea8baf851",
      },
    },
  },
  // Explicitly enable tools (actual execution still gated by permission below)
  "tools": {
    "read": true,
    "write": true,
    "edit": true,
    "patch": true,
    "bash": true,
    "webfetch": true,
    "task": true,
  },
  // Safer defaults for interactive use
  "permission": {
    "edit": "ask",
    "bash": "ask",
  },
  // Ignore noisy/generated paths for file watching
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", "target/**", "logs/**"],
  },
}
